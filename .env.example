# Server Configuration
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:port/geruso_detailing

# JWT Authentication
JWT_SECRET=your-secure-secret-key-change-in-production
JWT_EXPIRY=7d

# Email Configuration - RESEND (REQUIRED FOR QUOTE FORM TO WORK)
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=noreply@gerusodetailing.com

# Google Places API (OPTIONAL - Required for address autocomplete in booking form)
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Owner Contact - WHERE QUOTE EMAILS ARE SENT
OWNER_EMAIL=dumontdigital1@gmail.com

# Admin Setup
INITIAL_ADMIN_EMAIL=admin@gerusodetailing.com
INITIAL_ADMIN_PASSWORD=change-this-password

# Render
RENDER_EXTERNAL_URL=https://your-project.onrender.com
